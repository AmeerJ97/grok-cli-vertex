{
  "name": "grok-dev",
  "version": "1.1.6",
  "description": "A Vertex AI-focused Grok coding agent fork built with Bun and OpenTUI.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "grok": "dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "clean:dist": "bun -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\"",
    "build": "bun run clean:dist && tsc && bun -e \"import { chmodSync } from 'node:fs'; chmodSync('dist/index.js', 0o755)\"",
    "build:binary": "bun build --compile --outfile dist/grok-standalone ./src/index.ts",
    "prepack": "bun run build",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "lint": "biome check src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "lint:fix": "biome check --fix src/",
    "pre-commit": "lint-staged",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json}": "biome check --write --no-errors-on-unmatched"
  },
  "keywords": [
    "cli",
    "agent",
    "grok",
    "ai",
    "coding",
    "terminal",
    "opentui"
  ],
  "author": "AmeerJ97",
  "contributors": [
    "Vibe Kit (upstream project)"
  ],
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.43",
    "@ai-sdk/provider-utils": "^4.0.27",
    "@ai-sdk/xai": "^3.0.91",
    "@coinbase/agentkit": "^0.10.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@npmcli/arborist": "^9.6.0",
    "@opentui/core": "^0.2.15",
    "@opentui/react": "^0.2.15",
    "agent-desktop": "^0.2.0",
    "ai": "^6.0.190",
    "commander": "^14.0.3",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "google-auth-library": "^10.6.2",
    "grammy": "^1.43.0",
    "react": "^19.2.6",
    "ripgrep": "^0.3.1",
    "semver": "^7.8.1",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-types": "^3.17.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.9.1",
    "@types/npmcli__arborist": "^6.3.3",
    "@types/react": "^19.2.15",
    "@types/semver": "^7.7.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "preferGlobal": true
}
